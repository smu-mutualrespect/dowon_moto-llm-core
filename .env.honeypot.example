# Copy this file to .env.honeypot and fill in local-only secrets.
# Do not commit .env.honeypot.

# AWS CLI/client identity used against the local Moto honeypot.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# Moto server defaults.
MOTO_PORT=5000
MOTO_ACCOUNT_ID=123456789012

# Honeypot routing controls.
# true: replace weak/empty native Moto responses with the agent path where configured.
HONEYPOT_EARLY_OVERRIDE=true
HONEYPOT_INTERCEPT_NATIVE=true
HONEYPOT_INTERCEPT_NATIVE_SERVICES=sts,iam,s3,secretsmanager,ssm,cloudtrail,ec2

# true: use deterministic templates before cache/generic/LLM where templates exist.
HONEYPOT_TEMPLATE_FIRST=true

# Agent scheduling controls.
HONEYPOT_BACKGROUND_AFTER_TURNS=5
HONEYPOT_PREGEN_MIN_CONFIDENCE=0.6

# Model selection. Keep these fixed during benchmark comparisons.
MOTO_LLM_PROVIDER=claude
HONEYPOT_GENERATOR_MODEL=claude-sonnet-4-6
HONEYPOT_ANALYST_MODEL=gpt-5.4-mini
HONEYPOT_STRATEGIST_MODEL=gpt-5.4-mini
MOTO_LLM_OPENAI_MODEL=gpt-5.4-mini
MOTO_LLM_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Local-only API keys. Fill these in .env.honeypot, never in this example file.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional log paths. Leave defaults unless you want a separate benchmark run.
HONEYPOT_METRICS_PATH=/tmp/honeypot_metrics.jsonl
HONEYPOT_DEBUG_PATH=/tmp/honeypot_debug.jsonl
